{
  "name": "maxqwars.github.io",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "watch": {
    "build": {
      "patterns": [
        "js/**/*"
      ],
      "extensions": "js,ts"
    },
    "build:sw": "js/sw.ts"
  },
  "scripts": {
    "bs": "browser-sync start --no-open --no-notify -w -s _site -f _site",
    "build:sw": "esbuild js/sw.ts  --minify --bundle --external:node_modules/* --outfile=assets/js/sw.js",
    "build": "esbuild js/main.ts --splitting --minify --bundle --external:node_modules/* --format=esm --outdir=assets/js/",
    "watch": "npm-watch",
    "start": "concurrently \"jekyll serve\" \"npm run bs\" \"npm run watch\""
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "aos": "^2.3.4",
    "browser-sync": "^2.27.7",
    "chart.js": "^3.7.1",
    "concurrently": "^7.0.0",
    "esbuild": "^0.14.23",
    "feather-icons": "^4.28.0",
    "highlight.js": "^11.4.0",
    "millify": "^4.0.0",
    "npm-watch": "^0.11.0",
    "simple-jekyll-search": "^1.10.0",
    "typeit": "^8.3.1",
    "workbox-cacheable-response": "^6.5.0",
    "workbox-expiration": "^6.5.0",
    "workbox-routing": "^6.5.0",
    "workbox-strategies": "^6.5.0"
  }
}
